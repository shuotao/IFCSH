    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import sys\r\nimport clr\r\nimport System\r\nfrom System import Array\r\nfrom System.Collections.Generic import List, IList, Dictionary\r\n\r\nclr.AddReference('DocumentFormat.OpenXml')\r\nimport DocumentFormat\r\nfrom DocumentFormat.OpenXml import *\r\nfrom DocumentFormat.OpenXml.Packaging import *\r\nfrom DocumentFormat.OpenXml.Spreadsheet import *\r\n\r\nfilepath = IN[0]\r\n\r\nspreadsheetDoc = SpreadsheetDocument.Open(filepath, False)\r\nworkbookPart = spreadsheetDoc.WorkbookPart\r\nsheetsName = [s.Name.Value for s in spreadsheetDoc.WorkbookPart.Workbook.Sheets]\r\nspreadsheetDoc.Close()\r\n\r\nOUT = sheetsName",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "3c9ab62ae00c4c5693265c9334571c55",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "cb9f9081ea9b425dbadb265ec9c9d734",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "2e307a093bfa44a0a7e555ed962740f6",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
