      "Description": "Runs an embedded Python script."
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.DB.Structure import *\r\n\r\nclr.AddReference('RevitAPIUI')\r\nfrom Autodesk.Revit.UI import *\r\n\r\nclr.AddReference('System')\r\nfrom System.Collections.Generic import List\r\n\r\nclr.AddReference('RevitNodes')\r\nimport Revit\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\nclr.ImportExtensions(Revit.Elements)\r\n\r\nclr.AddReference('RevitServices')\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\nclr.AddReference('System.Windows.Forms')\r\nfrom System.Windows.Forms import *\r\nclr.AddReference('System.Drawing')\r\nfrom System.Drawing import *\r\nclr.AddReference('System')\r\nfrom System import *\r\n\r\nclr.AddReference('DSCoreNodes')\r\nfrom DSCore import Math\r\n\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nuidoc=DocumentManager.Instance.CurrentUIApplication.ActiveUIDocument\r\n\r\n#Preparing input from dynamo to revit\r\nif isinstance (IN[0], list):\r\n\tsheetList = IN[0]\r\nelse:\r\n\tsheetList = [IN[0]]\r\n\r\n\r\ndef GetDpiMultiplier():\r\n    graphics = Graphics.FromHwnd(IntPtr.Zero)\r\n    dpi = graphics.DpiX    \r\n    return dpi/96\r\n    \r\nclass CustomForm():\r\n    \r\n    def __init__(self):\r\n    \r\n        #class data\r\n        self.data = 'foo'\r\n        self.mul = GetDpiMultiplier()\r\n\r\n        self.inputs = []\r\n        #form\r\n        self.form = Form()\r\n        self.form.ShowIcon = False\r\n        self.form.MaximizeBox = False\r\n        self.form.FormBorderStyle = FormBorderStyle.FixedSingle\r\n        #self.form.AutoScaleMode = AutoScaleMode.Dpi\r\n        self.form.Size = Size(400*self.mul,500*self.mul)\r\n        self.form.MinimumSize = Size(400*self.mul,500*self.mul)\r\n        self.form.ClientSize = Size(378*self.mul,444*self.mul)\r\n        self.form.BackColor = Color.DimGray;\r\n  \r\n        #label\r\n        self.label = Label()\r\n        self.label.Parent = self.form\r\n        self.label.Location = Point(12*self.mul,9*self.mul)\r\n        self.label.Size = Size(200*self.mul,25*self.mul)\r\n        self.label.Text = 'Select Sheets'\r\n        \r\n        #checklistBox\r\n        self.chkListBox = CheckedListBox()\r\n        self.chkListBox.Parent = self.form\r\n        self.chkListBox.CheckOnClick = True\r\n        self.chkListBox.Items.AddRange(self.inputs)\r\n        self.chkListBox.Parent = self.form\r\n        self.chkListBox.Location = Point(12*self.mul,45*self.mul)\r\n        self.chkListBox.Size = Size(354*self.mul,340*self.mul)\r\n        self.chkListBox.Anchor = (AnchorStyles.Bottom)|(AnchorStyles.Right)|(AnchorStyles.Top)|(AnchorStyles.Left)\r\n        #checkbox\r\n        self.chkBox = CheckBox()\r\n        self.chkBox.Parent = self.form\r\n        self.chkBox.CheckOnClick = True\r\n        self.chkBox.Text = 'Select All'\r\n        self.chkBox.Location = Point(12*self.mul, 403*self.mul)\r\n        self.chkBox.Size = Size(113*self.mul,29*self.mul)\r\n        self.chkBox.Anchor = (AnchorStyles.Bottom)|(AnchorStyles.Left)        \r\n        #buttons\r\n        self.button1 = Button()\r\n        self.button1.Text = 'Confirm'\r\n        self.button1.Name = 'Confirm'\r\n        self.button1.Parent = self.form\r\n        self.button1.Location = Point(136*self.mul,398*self.mul)\r\n        self.button1.Size = Size(112*self.mul,34*self.mul)\r\n        self.button1.Anchor = (AnchorStyles.Bottom)|(AnchorStyles.Right)\r\n        \r\n        self.button2 = Button()\r\n        self.button2.Text = 'Cancel'\r\n        self.button2.Name = 'Cancel'\r\n        self.button2.Parent = self.form\r\n        self.button2.Location = Point(254*self.mul,398*self.mul)\r\n        self.button2.Size = Size(112*self.mul,34*self.mul)\r\n        self.button2.Anchor = (AnchorStyles.Bottom)|(AnchorStyles.Right)\r\n        \r\n        #events\r\n        \r\n        self.form.Load += self.formLoadHandler\r\n        self.button1.Click += self.buttonClickHandler\r\n        self.button2.Click += self.buttonClickHandler        \r\n        self.chkBox.CheckedChanged += self.chkStateEventHandler\r\n    \r\n    def Show(self):\r\n        self.chkListBox.Items.AddRange(self.inputs)\r\n        self.form.ShowDialog()\r\n                \r\n    def chkStateEventHandler(self, sender, args):\r\n        if(sender.Checked):\r\n            self.chkListBox.Enabled = False\r\n            self.chkListBox.BackColor = SystemColors.ScrollBar\r\n        else:\r\n            self.chkListBox.Enabled = True\r\n            self.chkListBox.BackColor = SystemColors.Window\r\n   \r\n        \r\n    def keyPressHandler(self, sender, args):\r\n\r\n        if (args.KeyCode == Keys.Enter):\r\n           self.buttonClickHandler(self.button1, args)\r\n\t\t\r\n    def buttonClickHandler(self, sender, args):\r\n        if(sender.Name == 'Cancel'):\r\n            self.form.Close()\r\n        if(sender.Name == 'Confirm'):\r\n            if self.chkBox.Checked:\r\n                self.data = self.chkListBox.Items\r\n            else:\r\n                self.data = self.chkListBox.CheckedItems\r\n            self.form.Close()\r\n\r\n    def formLoadHandler(self, sender, args):\r\n        sender.Text = 'Dynamo IFC-SG'\r\n\r\n\r\n\r\ncf = CustomForm()\r\ncf.inputs = sheetList\r\ncf.Show()\r\n\r\noutVal = []\r\nfor sheet in sheetList:\r\n    if sheet in cf.data:\r\n        outVal.append(sheet)\r\n\r\n \r\n\r\nOUT = outVal",
